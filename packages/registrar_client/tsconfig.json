{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ESNext",
    "resolveJsonModule": true,

    /* Modules */
    "module": "commonjs",
    /* Emit */

    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./src", "scripts"],
  "exclude": ["./tests"]
}
